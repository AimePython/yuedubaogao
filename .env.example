# 复制本文件为 .env 后填写。OpenAI 与阿里云百炼二选一（勿同时泄露两套 Key）。

# ---------- OpenAI（默认示例）----------
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# ---------- 阿里云百炼 DeepSeek-v3.2（OpenAI 兼容）----------
# 使用百炼时注释掉上面三行，改为以下配置（文档: https://help.aliyun.com/zh/model-studio/deepseek-api ）
# LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_API_KEY=sk-你的百炼APIKey
# LLM_MODEL=deepseek-v3.2
# LLM_ENABLE_THINKING=false
# LLM_HTTP_TIMEOUT=90

CORS_ALLOW_ORIGIN=*
ENABLE_QUERY_LOG=true
ADMIN_TOKEN=
SESSION_MAX_TURNS=3
ENABLE_TOOL_AGENT=true
TOOL_AGENT_MAX_ROUNDS=5
AGENT_TEMPERATURE=0.15
